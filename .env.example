# Base app settings
APP_ENV=development
APP_NAME=Podcast Anything Local
DATA_DIR=./data
DATABASE_PATH=./data/app.db
JOBS_DIR=./data/jobs
WEB_EXTRACTOR=auto

# Recommended local setup
REWRITE_PROVIDER=ollama
REWRITE_STYLE=podcast
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=gemma3:4b
OLLAMA_GENERATE_TIMEOUT_SECONDS=600

TTS_PROVIDER=piper
TTS_DEFAULT_VOICE=
TTS_DUO_VOICE=
PIPER_MODEL_PATH=./data/piper_voices/en_US-lessac-high.onnx
PIPER_MODEL_PATH_B=./data/piper_voices/en_US-ryan-high.onnx
PIPER_CONFIG_PATH=./data/piper_voices/en_US-lessac-high.onnx.json
PIPER_CONFIG_PATH_B=./data/piper_voices/en_US-ryan-high.onnx.json
PIPER_SPEAKER_ID=
PIPER_SPEAKER_ID_B=

# Optional hosted rewrite provider
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional hosted TTS provider
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Development-only fallback providers
# REWRITE_PROVIDER=demo
# TTS_PROVIDER=wave
