# Base app settings
APP_ENV=development
APP_NAME=Podcast Anything Local
DATA_DIR=./data
DATABASE_PATH=./data/app.db
JOBS_DIR=./data/jobs
WEB_EXTRACTOR=auto

# Podcast script writing
REWRITE_STYLE=podcast
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PODCAST_LENGTH_DEFAULT=medium

# Podcast voice generation
TTS_PROVIDER=openai

# OpenAI TTS defaults
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_VOICE_B=cedar
OPENAI_TTS_RESPONSE_FORMAT=wav

# Optional alternate hosted TTS provider
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_DIALOGUE_MODEL_ID=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID_B=
