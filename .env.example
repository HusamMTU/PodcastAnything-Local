# Base app settings
APP_ENV=development
APP_NAME=Podcast Anything Local
DATA_DIR=./data
DATABASE_PATH=./data/app.db
JOBS_DIR=./data/jobs
WEB_EXTRACTOR=auto

# Podcast script writing
REWRITE_STYLE=podcast
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Podcast voice generation
TTS_PROVIDER=piper
TTS_DEFAULT_VOICE=./data/piper_voices/en_US-ryan-high.onnx
TTS_DUO_VOICE=
PIPER_MODEL_PATH=./data/piper_voices/en_US-lessac-high.onnx
PIPER_MODEL_PATH_B=./data/piper_voices/en_US-ryan-high.onnx
PIPER_CONFIG_PATH=./data/piper_voices/en_US-lessac-high.onnx.json
PIPER_CONFIG_PATH_B=./data/piper_voices/en_US-ryan-high.onnx.json
PIPER_SPEAKER_ID=
PIPER_SPEAKER_ID_B=

# Optional hosted TTS provider
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
